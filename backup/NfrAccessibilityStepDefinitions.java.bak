package com.app.qa.coresuite.stepdefinitions;

import com.app.qa.coresuite.support.TestContext;
import com.deque.html.axe.selenium.AxeBuilder;
import com.deque.html.axe.selenium.Results;
import io.cucumber.java.en.Then;
import static org.junit.jupiter.api.Assertions.*;
import java.util.stream.Collectors;

public class NfrAccessibilityStepDefinitions {
    @Then("the page should pass accessibility audits")
    public void checkAccessibility() {
        Results results = new AxeBuilder().analyze(TestContext.getDriver());
        assertTrue(results.getViolations().isEmpty(), 
            "Accessibility violations found: " + 
            results.getViolations().stream()
                   .map(v -> v.getHelp())
                   .collect(Collectors.joining(", ")));
    }
}